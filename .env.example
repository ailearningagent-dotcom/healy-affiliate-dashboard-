# ====================================
# MarketAI - Environment Variables
# ====================================
# Copy this file to .env.local and fill in your values

# --- Authentication ---
# Set a password to protect your MarketAI dashboard.
# In development, auth is skipped if this is not set.
ADMIN_PASSWORD=your-secure-password-here

# NextAuth secret — used to encrypt session tokens and CSRF tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-at-least-32-chars-long

# --- Database ---
# Local SQLite database (default, no setup needed)
DATABASE_URL=file:./data/marketai.db

# For remote Turso database (optional, replace URL above):
# DATABASE_URL=libsql://your-db.turso.io
# DATABASE_AUTH_TOKEN=your-turso-token

# --- AI Provider Keys ---
# You only need ONE provider to run all agents.
# OpenAI is recommended as the default.

# OpenAI API Key (recommended)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Google Gemini API Key (free tier available)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# Anthropic Claude API Key
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API Key (access multiple models via one API)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# --- Default AI Provider (optional) ---
# Override the default AI provider for all server-side agents (pipeline, followups, auto-booker).
# Leave unset to use Gemini (free tier available).
# Options: openai | gemini | claude | openrouter | groq | deepseek | xai | mistral | together
# DEFAULT_AI_PROVIDER=gemini
# DEFAULT_AI_MODEL=gemini-2.0-flash-lite

# --- Groq API Key (optional) ---
# Ultra-fast inference. Hosts Llama, Mixtral, Gemma models.
# Get key at: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# --- DeepSeek API Key (optional) ---
# Extremely cheap AI (1/10th cost of GPT-4o). DeepSeek V4 Flash & Pro.
# Get key at: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...

# --- xAI (Grok) API Key (optional) ---
# Grok 4.3 models via xAI.
# Get key at: https://console.x.ai
# XAI_API_KEY=xai-...

# --- Mistral AI API Key (optional) ---
# Mistral Large, Small, Codestral, Ministral models.
# Get key at: https://console.mistral.ai
# MISTRAL_API_KEY=...

# --- Together AI API Key (optional) ---
# Hosts 200+ open-source models (Llama, DeepSeek, Qwen, Gemma).
# Get key at: https://api.together.ai/settings/api-keys
# TOGETHER_API_KEY=...

# --- Chrome / Puppeteer (optional) ---
# Path to Chrome executable for Google Maps scraping and WhatsApp Web.
# Defaults to standard install location if not set.
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# --- Next.js ---
# (Optional) Set the base URL for production
# NEXT_PUBLIC_BASE_URL=https://your-domain.com
